<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.Arise" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme using core-splashscreen -->
    <style name="Theme.Arise.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A0F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_arise_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Arise</item>
    </style>
</resources>
